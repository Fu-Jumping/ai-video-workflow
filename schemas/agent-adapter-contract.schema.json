{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-video-workflow.local/schemas/agent-adapter-contract.schema.json",
  "title": "AI Video Workflow Agent Adapter Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapterId",
    "displayName",
    "inputs",
    "outputs",
    "syncDirection",
    "sourceOfTruth",
    "failureBehavior"
  ],
  "properties": {
    "adapterId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapterPath"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapterPath"
      }
    },
    "syncDirection": {
      "type": "string",
      "enum": [
        "runtime-mirror",
        "one-way-project-to-adapter",
        "read-only-context"
      ]
    },
    "sourceOfTruth": {
      "const": "project-step-files"
    },
    "handoffSurfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "sharedEntryPoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "generatedSurfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "userOwnedSurfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "privateRuntimeSurfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "verificationCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "forbiddenWrites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapterPath"
      },
      "default": []
    },
    "failureBehavior": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "adapterPath": {
      "type": "string",
      "minLength": 1
    }
  }
}

{
  "adapterId": "claude-code",
  "displayName": "Claude Code",
  "inputs": [
    "packs/official-ai-video/",
    "project.config.yaml",
    "01_concept/",
    "02_setting/",
    "03_storyboard/",
    "04_image_prompts/",
    "05_video_prompts/",
    "06_execution_plan/"
  ],
  "outputs": [
    "CLAUDE.md",
    ".claude/skills/",
    ".claude/commands/",
    ".claude/ai-video-workflow/"
  ],
  "syncDirection": "runtime-mirror",
  "sourceOfTruth": "project-step-files",

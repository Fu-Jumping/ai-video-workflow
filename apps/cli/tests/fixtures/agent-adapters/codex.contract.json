{
  "adapterId": "codex",
  "displayName": "Codex",
  "inputs": [
    "packs/official-ai-video/",
    "project.config.yaml",
    "01_concept/",
    "02_setting/",
    "03_storyboard/",
    "04_image_prompts/",
    "05_video_prompts/",
    "06_execution_plan/"
  ],
  "outputs": [
    ".codex/ai-video-workflow/",
    ".codex/skills/"
  ],
  "syncDirection": "runtime-mirror",
  "sourceOfTruth": "project-step-files",
  "handoffSurfaces": [
    ".codex/skills/film-workflow/SKILL.md",
    ".codex/ai-video-workflow/WORKFLOW_OVERVIEW.md"
  ],
  "verificationCommands": [
    "ai-video-workflow verify --project <path> --ide codex"
  ],
  "forbiddenWrites": [
    "Workflow/",
    "Shots/",
    "Canvas/",
    "Bases/",
    ".obsidian/",
    "absolute links"
  ],
  "failureBehavior": "Report missing or stale runtime files through verification; rerun sync to rebuild Codex runtime mirrors without changing source Step files."
}
